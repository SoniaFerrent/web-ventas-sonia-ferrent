{
  "redirects": [
    {"source": "/index.html", "destination": "/inicio", "permanent": true},
    {"source": "/consultoria.html", "destination": "/consultoria-de-ventas", "permanent": true},
    {"source": "/consultoriadeventas/", "destination": "/consultoria-de-ventas", "permanent": true},
    {"source": "/sobre-mi.html", "destination": "/sonia-ferrer-rentero-consultora-de-ventas", "permanent": true},
    {"source": "/sonia-ferrer-rentero/", "destination": "/sonia-ferrer-rentero-consultora-de-ventas", "permanent": true},
    {"source": "/contacto.html", "destination": "/contacto", "permanent": true},
    {"source": "/contact/", "destination": "/contacto", "permanent": true}
  ],
  "rewrites": [
    {"source": "/inicio", "destination": "/index.html"},
    {"source": "/consultoria-de-ventas", "destination": "/consultoria.html"},
    {"source": "/sonia-ferrer-rentero-consultora-de-ventas", "destination": "/sobre-mi.html"},
    {"source": "/contacto", "destination": "/contacto.html"}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://forms-api.basestack.co; form-action 'self' https://forms-api.basestack.co; frame-ancestors 'none'; base-uri 'self'; object-src 'none';"
        }
      ]
    }
  ]
}
