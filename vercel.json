    {"source": "/formacion-comercial.html", "destination": "/formacion-comercial", "permanent": true},
    {"source": "/consultoria-de-ventas-saas.html", "destination": "/consultoria-de-ventas-saas", "permanent": true},
    {"source": "/consultoria-de-ventas-para-pymes.html", "destination": "/consultoria-de-ventas-para-pymes", "permanent": true},
    {"source": "/recursos-de-ventas.html", "destination": "/recursos-de-ventas", "permanent": true},
    {"source": "/aviso-legal.html", "destination": "/aviso-legal", "permanent": true}
  ],
  "rewrites": [
    {"source": "/inicio", "destination": "/index.html"},
    {"source": "/consultoria-de-ventas", "destination": "/consultoria.html"},
    {"source": "/sonia-ferrer-rentero-consultora-de-ventas", "destination": "/sobre-mi.html"},
    {"source": "/contacto", "destination": "/contacto.html"},
    {"source": "/estrategia-de-ventas-y-growth", "destination": "/estrategia-de-ventas-y-growth.html"},
    {"source": "/IA-en-ventas-y-growth", "destination": "/IA-en-ventas-y-growth.html"},
    {"source": "/consultoria-growth-para-startups", "destination": "/consultoria-growth-para-startups.html"},
    {"source": "/plan-de-ventas", "destination": "/plan-de-ventas.html"},
    {"source": "/procesos-comerciales-y-automatizacion-de-ventas", "destination": "/procesos-comerciales-y-automatizacion-de-ventas.html"},
    {"source": "/funnel-de-ventas", "destination": "/funnel-de-ventas.html"},
    {"source": "/estrategias-de-generacion-de-demanda", "destination": "/estrategias-de-generacion-de-demanda.html"},
    {"source": "/formacion-comercial", "destination": "/formacion-comercial.html"},
    {"source": "/consultoria-de-ventas-saas", "destination": "/consultoria-de-ventas-saas.html"},
    {"source": "/consultoria-de-ventas-para-pymes", "destination": "/consultoria-de-ventas-para-pymes.html"},
    {"source": "/recursos-de-ventas", "destination": "/recursos-de-ventas.html"},
    {"source": "/aviso-legal", "destination": "/aviso-legal.html"}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://formspree.io https://vitals.vercel-insights.com; form-action 'self' https://formspree.io; frame-ancestors 'none'; base-uri 'self'; object-src 'none';"
        }
      ]
    }
  ]
}
